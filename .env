# ==============================================
# PHANTOM CHAT - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/phantomchat
# For production: mongodb+srv://user:pass@cluster.mongodb.net/phantomchat

# Session Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=secret_key
# Encryption
# AES-256 key (32 bytes = 64 hex chars)
ENCRYPTION_KEY=key
# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
MESSAGE_RATE_LIMIT_MAX=30

# Message Auto-Delete (hours)
DEFAULT_MSG_TTL_HOURS=24
MAX_MSG_TTL_HOURS=168

# Room Settings
MAX_ROOM_MEMBERS=50
MAX_ROOMS_PER_USER=5

# Security
BCRYPT_ROUNDS=12
MAX_MESSAGE_LENGTH=2000
MAX_USERNAME_LENGTH=20
